#include <bits/stdc++.h>
using namespace std;

string rearrangeString(string s)
{
    int n = s.size();

    vector<int> freq(26, 0);
    int mxFreq = 0;

    for (char ch : s)
    {
        freq[ch - 'a']++;
        mxFreq = max(mxFreq, freq[ch - 'a']);
    }

    // Not possible
    if (mxFreq > (n + 1) / 2)
        return "NO SOLUTION";

    priority_queue<pair<int, char>> pq;

    for (int i = 0; i < 26; i++)
    {
        if (freq[i] > 0)
            pq.push({freq[i], char('a' + i)});
    }

    string ans;

    pair<int, char> prev = {0, '#'}; // {remaining freq, char}

    while (!pq.empty())
    {
        auto curr = pq.top();
        pq.pop();

        ans += curr.second;
        curr.first--;

        if (prev.first > 0)
            pq.push(prev);

        prev = curr;
    }

    return (ans.size() == n) ? ans : "NO SOLUTION";
}
