#include <bits/stdc++.h>
using namespace std;

void printTopView(BinaryTreeNode<int> *root) {
    if (root == NULL) return;

    map<int, int> mp;
    queue<pair<BinaryTreeNode<int>*, int>> q;
    q.push({root, 0});

    while (!q.empty()) {
        auto curr = q.front();
        q.pop();

        BinaryTreeNode<int>* node = curr.first;
        int hd = curr.second;

        if (mp.find(hd) == mp.end()) {
            mp[hd] = node->data;
        }

        if (node->left) {
            q.push({node->left, hd - 1});
        }

        if (node->right) {
            q.push({node->right, hd + 1});
        }
    }

    for (auto &it : mp) {
        cout << it.second << " ";
    }
}
