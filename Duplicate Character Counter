#include <bits/stdc++.h>
using namespace std;

int countRepeatingChars(string s) {
    vector<int> freq(26, 0);

    for (char ch : s) {
        freq[ch - 'a']++;
    }

    int count = 0;

    for (int i = 0; i < 26; i++) {
        if (freq[i] > 1) {
            count++;
        }
    }

    return (count == 0) ? -1 : count;
}
