bool isCircular(string moves) {
    int x = 0, y = 0;
    int dir = 0; // 0=N, 1=E, 2=S, 3=W

    for (char move : moves) {
        if (move == 'G') {
            if (dir == 0) y++;
            else if (dir == 1) x++;
            else if (dir == 2) y--;
            else x--;
        } 
        else if (move == 'L') {
            dir = (dir + 3) % 4;
        } 
        else if (move == 'R') {
            dir = (dir + 1) % 4;
        }
    }

    return (x == 0 && y == 0);
}
