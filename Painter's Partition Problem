#include <bits/stdc++.h>
using namespace std;

bool isPossible(vector<int>& arr, int n, int k, long long mid) {
    
    int painters = 1;
    long long boardSum = 0;

    for (int i = 0; i < n; i++) {

        if (boardSum + arr[i] <= mid) {
            boardSum += arr[i];
        }
        else {
            painters++;
            boardSum = arr[i];

            if (painters > k)
                return false;
        }
    }

    return true;
}

long long findLargestMinDistance(vector<int>& boards, int k)
{
    int n = boards.size();

    long long start = 0;
    long long sum = 0;

    for (int x : boards) {
        sum += x;
        start = max(start, (long long)x);
    }

    long long end = sum;
    long long ans = end;

    while (start <= end) {

        long long mid = start + (end - start) / 2;

        if (isPossible(boards, n, k, mid)) {
            ans = mid;
            end = mid - 1;
        }
        else {
            start = mid + 1;
        }
    }

    return ans;
}
