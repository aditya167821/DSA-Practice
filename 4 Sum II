#include <bits/stdc++.h>
using namespace std;

int fourSum(int n, vector<int> &A, vector<int> &B, vector<int> &C, vector<int> &D) {
    unordered_map<int, int> mp;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            mp[A[i] + B[j]]++;
        }
    }

    int count = 0;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            int sum = C[i] + D[j];
            if (mp.find(-sum) != mp.end()) {
                count += mp[-sum];
            }
        }
    }

    return count;
}
