#include <bits/stdc++.h>
using namespace std;

bool CheckIdempotent(int **mat, int n) {

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {

            int val = 0;

            for (int k = 0; k < n; k++) {
                val += mat[i][k] * mat[k][j];
            }

           
            if (val != mat[i][j]) {
                return false;
            }
        }
    }

    return true;
}
