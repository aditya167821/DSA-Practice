#include <bits/stdc++.h>
using namespace std;

int maxMoneyLooted(vector<int> &arr, int n)
{
    if (n == 0) return 0;
    if (n == 1) return arr[0];

    int prev2 = arr[0];
    int prev1 = max(arr[0], arr[1]);

    for (int i = 2; i < n; i++)
    {
        int take = arr[i] + prev2;
        int notTake = prev1;

        int curr = max(take, notTake);

        prev2 = prev1;
        prev1 = curr;
    }

    return prev1;
}
