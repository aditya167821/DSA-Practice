int makeBeautiful(string str) 
{
    int count1 = 0;
    int count2 = 0;

    for (int i = 0; i < str.length(); i++)
    {
        char expected1 = (i % 2 == 0) ? '0' : '1';
        char expected2 = (i % 2 == 0) ? '1' : '0';

        if (str[i] != expected1)
        {
            count1++;
        }

        if (str[i] != expected2)
        {
            count2++;
        }
    }

    return min(count1, count2);
}
