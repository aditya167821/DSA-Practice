#include <bits/stdc++.h>
using namespace std;

string getCompressedString(string &s)
{
    string ans = "";
    int n = s.length();

    for (int i = 0; i < n; i++)
    {
        int count = 1;

        while (i < n - 1 && s[i] == s[i + 1])
        {
            count++;
            i++;
        }

        ans += s[i];

        if (count > 1)
        {
            ans += to_string(count);
        }
    }

    return ans;
}
