vector<int> findArrayIntersection(vector<int> &A, int n, vector<int> &B, int m)
{
    vector<int> ans;

    int i = 0, j = 0;

    while(i < n && j < m)
    {
        if(A[i] == B[j])
        {
            ans.push_back(A[i]);
            i++;
            j++;
        }
        else if(A[i] < B[j])
        {
            i++;
        }
        else
        {
            j++;
        }
    }

    return ans;
}
