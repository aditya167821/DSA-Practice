#include <bits/stdc++.h>
using namespace std;

int weightOfLastStone(int arr[], int n) {
    priority_queue<int> pq;

    for (int i = 0; i < n; i++)
        pq.push(arr[i]);

    while (pq.size() > 1) {
        int y = pq.top();
        pq.pop();

        int x = pq.top();
        pq.pop();

        if (x != y)
            pq.push(y - x);
    }

    return pq.empty() ? 0 : pq.top();
}
