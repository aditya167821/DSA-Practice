#include <bits/stdc++.h>
using namespace std;

bool canSplit(vector<int>& a, int k, long long maxSum) {
    long long currSum = 0;
    int parts = 1;

    for (int x : a) {
        if (currSum + x > maxSum) {
            parts++;
            currSum = x;

            if (parts > k)
                return false;
        } else {
            currSum += x;
        }
    }

    return true;
}

int largestSubarraySumMinimized(vector<int> a, int k) {
    long long low = *max_element(a.begin(), a.end());
    long long high = accumulate(a.begin(), a.end(), 0LL);

    long long ans = high;

    while (low <= high) {
        long long mid = low + (high - low) / 2;

        if (canSplit(a, k, mid)) {
            ans = mid;
            high = mid - 1;
        } else {
            low = mid + 1;
        }
    }

    return (int)ans;
}
