#include <bits/stdc++.h>
using namespace std;

bool isPerfectSquare(int x) {
    int r = sqrt(x);
    return r * r == x;
}

int ans;

void dfs(vector<int>& arr, vector<vector<int>>& graph,
         vector<bool>& used, int idx, int count) {

    int n = arr.size();

    if (count == n) {
        ans++;
        return;
    }

    used[idx] = true;

    for (int next : graph[idx]) {

        if (used[next])
            continue;

        if (next > 0 && arr[next] == arr[next - 1] && !used[next - 1])
            continue;

        dfs(arr, graph, used, next, count + 1);
    }

    used[idx] = false;
}

int numberOfSquarefulArrays(vector<int> arr, int n) {

    sort(arr.begin(), arr.end());

    vector<vector<int>> graph(n);

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {

            if (i != j && isPerfectSquare(arr[i] + arr[j])) {
                graph[i].push_back(j);
            }
        }
    }

    ans = 0;

    vector<bool> used(n, false);

    for (int i = 0; i < n; i++) {

        if (i > 0 && arr[i] == arr[i - 1])
            continue;

        dfs(arr, graph, used, i, 1);
    }

    return ans;
}
