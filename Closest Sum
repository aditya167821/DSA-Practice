#include <bits/stdc++.h>
using namespace std;

int closest3Sum(vector<int> arr, int n, int target) {
    sort(arr.begin(), arr.end());

    long long bestSum = (long long)arr[0] + arr[1] + arr[2];

    for (int i = 0; i < n - 2; i++) {
        int left = i + 1;
        int right = n - 1;

        while (left < right) {
            long long currSum = (long long)arr[i] + arr[left] + arr[right];

            long long currDiff = llabs(currSum - target);
            long long bestDiff = llabs(bestSum - target);

            if (currDiff < bestDiff ||
                (currDiff == bestDiff && currSum < bestSum)) {
                bestSum = currSum;
            }

            if (currSum < target) {
                left++;
            } else if (currSum > target) {
                right--;
            } else {
                return (int)currSum; // exact match
            }
        }
    }

    return (int)bestSum;
}
