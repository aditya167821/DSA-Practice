#include <iostream>
#include <string>
using namespace std;

void printSubstrings(string str) {
    int n = str.length();

    for (int i = 0; i < n; i++) {
        string temp = "";

        for (int j = i; j < n; j++) {
            temp += str[j];
            cout << temp << endl;
        }
    }
}
