int* getProductArrayExceptSelf(int *arr, int n)
{
    const long long MOD = 1000000007;

    int *product = new int[n];

    long long prefix = 1;

    for(int i = 0; i < n; i++)
    {
        product[i] = prefix;
        prefix = (prefix * arr[i]) % MOD;
    }

    long long suffix = 1;

    for(int i = n - 1; i >= 0; i--)
    {
        product[i] = (1LL * product[i] * suffix) % MOD;
        suffix = (suffix * arr[i]) % MOD;
    }

    return product;
}
